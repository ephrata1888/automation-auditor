# LLM: Groq (free tier, no credit card required). Get a key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: Override model (default: llama-3.3-70b-versatile). Faster: llama-3.1-8b-instant
# LLM_MODEL=llama-3.3-70b-versatile

# Vision: Google Gemini for diagram analysis (optional)
# GEMINI_API_KEY=your_gemini_api_key_here

# LangSmith tracing (optional)
# LANGCHAIN_API_KEY=your_api_key_here
# LANGCHAIN_PROJECT=automation-auditor
# LANGCHAIN_TRACING_V2=true